generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url moved to prisma.config.ts (Prisma 7 requirement)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(MEMBER)
  boards    Board[]  @relation("BoardOwner")
  tasks     Task[]   @relation("TaskAssignee")
  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Board {
  id          String   @id @default(cuid())
  title       String
  description String?
  ownerId     String
  owner       User     @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  columns     Column[]
  tasks       Task[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Column {
  id        String @id @default(cuid())
  title     String
  order     Int
  boardId   String
  board     Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  tasks     Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boardId, order])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   // Will be synced with Column title
  priority    Priority @default(MEDIUM)
  order       Int
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])

  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  activities  Activity[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([columnId, order])
}

model Activity {
  id        String   @id @default(cuid())
  action    String   // e.g. "TASK_CREATED", "TASK_MOVED", "TASK_COMPLETED"
  details   Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}